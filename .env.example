# Frontend Configuration
# API Gateway endpoint URL
REACT_APP_API_BASE=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# AWS Configuration (if running locally for testing)
AWS_REGION=us-east-1
AWS_PROFILE=default

# Backend Configuration (Lambda environment variables)
TABLE_NAME=event-system-table
QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/event-queue
ARCHIVE_BUCKET=event-archives-bucket
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:event-notifications
STATE_MACHINE_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:event-processor
